<h1>Synthesis Runs</h1>

<p><%= link_to "New Synthesis Run", new_synthesis_run_path %></p>
<p><%= link_to "Run Test", seed_test_synthesis_runs_path %></p>

<% if @synthesis_runs.any? %>
  <style>
    .gray { background-color: #f1f3f5; color: #111827; }
    .yellow { background-color: #fff3bf; color: #111827; }
    .green { background-color: #d3f9d8; color: #111827; }
    .red { background-color: #ffe3e3; color: #111827; }
    .gray a, .yellow a, .green a, .red a { color: #1f2937; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
  </style>

  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Status</th>
        <th>IMF Type</th>
        <th>Age (Gyr)</th>
        <th>Metallicity (Z)</th>
        <th>SFH Model</th>
        <th>Created At</th>
        <th>Show</th>
      </tr>
    </thead>
    <tbody>
      <% @synthesis_runs.each do |run| %>
        <% row_class = case run.status.to_s
                       when "pending" then "gray"
                       when "running" then "yellow"
                       when "complete" then "green"
                       when "failed" then "red"
                       else ""
                       end %>
        <tr class="<%= row_class %>">
          <td><%= run.name.presence || "Run ##{run.id}" %></td>
          <td><%= run.status %></td>
          <td><%= run.imf_type %></td>
          <td><%= run.age_gyr %></td>
          <td><%= run.metallicity_z %></td>
          <td><%= run.sfh_model %></td>
          <td><%= run.created_at %></td>
          <td><%= link_to "Show", synthesis_run_path(run) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No synthesis runs yet.</p>
<% end %>
