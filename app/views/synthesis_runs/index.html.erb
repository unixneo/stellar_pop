<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h1 class="card-title">Synthesis Runs</h1>
      <p class="card-subtitle">Manage and inspect stellar population runs.</p>
    </div>
  </div>
  <div class="cyberspace-panel-body action-links">
    <%= link_to "New Synthesis Run", new_synthesis_run_path %>
    <%= link_to "Run Test", seed_test_synthesis_runs_path %>
  </div>
</div>

<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h2 class="card-title">Run Table</h2>
    </div>
  </div>
  <div class="cyberspace-panel-body">
    <% if @synthesis_runs.any? %>
      <div class="table-wrap">
        <table class="synthesis-runs-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Status</th>
              <th>IMF Type</th>
              <th>Age (Gyr)</th>
              <th>Metallicity (Z)</th>
              <th>SFH Model</th>
              <th class="run-created-at-col">Created At</th>
            </tr>
          </thead>
          <tbody>
            <% @synthesis_runs.each do |run| %>
              <tr>
                <td class="run-name-cell">
                  <% run_label = run.name.presence || "Run ##{run.id}" %>
                  <%= link_to(run_label, synthesis_run_path(run), class: "run-name-link", title: run_label) %>
                </td>
                <td><%= run.status %></td>
                <td><%= run.imf_type %></td>
                <td><%= run.age_gyr %></td>
                <td><%= run.metallicity_z %></td>
                <td><%= run.sfh_model %></td>
                <td class="run-created-at-col"><%= run.created_at %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p>No synthesis runs yet.</p>
    <% end %>
  </div>
</div>
