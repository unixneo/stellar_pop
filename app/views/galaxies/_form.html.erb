<%= form_with model: galaxy do |f| %>
  <div class="form-card">
    <table class="galaxy-form-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><%= f.label :name %></td>
          <td><%= f.text_field :name %></td>
        </tr>
        <tr>
          <td><%= f.label :galaxy_type %></td>
          <td><%= f.text_field :galaxy_type %></td>
        </tr>
        <tr>
          <td><%= f.label :notes %></td>
          <td><%= f.text_area :notes, rows: 3 %></td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="form-card">
    <table class="galaxy-form-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><%= f.label :ra, "RA" %></td>
          <td><%= f.number_field :ra, step: 0.0001 %></td>
        </tr>
        <tr>
          <td><%= f.label :dec, "Dec" %></td>
          <td><%= f.number_field :dec, step: 0.0001 %></td>
        </tr>
        <tr>
          <td><%= f.label :redshift_z %></td>
          <td><%= f.number_field :redshift_z, step: 0.000001 %></td>
        </tr>
        <tr>
          <td><%= f.label :agn %></td>
          <td><%= f.check_box :agn %></td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="form-card">
    <table class="galaxy-form-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><%= f.label :mag_u %></td>
          <td><%= f.number_field :mag_u, step: 0.0001 %></td>
        </tr>
        <tr>
          <td><%= f.label :mag_g %></td>
          <td><%= f.number_field :mag_g, step: 0.0001 %></td>
        </tr>
        <tr>
          <td><%= f.label :mag_r %></td>
          <td><%= f.number_field :mag_r, step: 0.0001 %></td>
        </tr>
        <tr>
          <td><%= f.label :mag_i %></td>
          <td><%= f.number_field :mag_i, step: 0.0001 %></td>
        </tr>
        <tr>
          <td><%= f.label :mag_z %></td>
          <td><%= f.number_field :mag_z, step: 0.0001 %></td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="form-card">
    <table class="galaxy-form-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><%= f.label :sdss_dr %></td>
          <td><%= f.text_field :sdss_dr %></td>
        </tr>
        <tr>
          <td><%= f.label :sdss_objid %></td>
          <td><%= f.text_field :sdss_objid %></td>
        </tr>
        <tr>
          <td><%= f.label :source_catalog %></td>
          <td><%= f.text_field :source_catalog %></td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="form-card">
    <p><%= f.submit %></p>
  </div>
<% end %>
