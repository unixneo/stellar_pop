<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h1 class="card-title">Pipeline Configuration</h1>
      <p class="card-subtitle">Edit runtime constants used by synthesis, grid fitting, and benchmark jobs.</p>
    </div>
  </div>

  <%= form_with model: @pipeline_config, url: pipeline_config_path, method: :patch, html: { class: "pipeline-config-form" } do |f| %>
    <div class="form-card">
      <h2>Synthesis Pipeline</h2>
      <table>
        <thead>
          <tr><th>Name</th><th>Value</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><%= f.label :synthesis_age_bins_gyr, "Age bins (Gyr, comma-separated)" %></td>
            <td><%= f.text_field :synthesis_age_bins_gyr, value: Array(@settings["synthesis_age_bins_gyr"]).join(", ") %></td>
          </tr>
          <tr>
            <td><%= f.label :synthesis_imf_sample_size, "IMF sample size" %></td>
            <td><%= f.number_field :synthesis_imf_sample_size, value: @settings["synthesis_imf_sample_size"], min: 10, step: 10 %></td>
          </tr>
          <tr>
            <td><%= f.label :synthesis_exponential_tau, "Exponential SFH tau (Gyr)" %></td>
            <td><%= f.number_field :synthesis_exponential_tau, value: @settings["synthesis_exponential_tau"], step: 0.1 %></td>
          </tr>
          <tr>
            <td><%= f.label :synthesis_delayed_exponential_tau, "Delayed-exponential SFH tau (Gyr)" %></td>
            <td><%= f.number_field :synthesis_delayed_exponential_tau, value: @settings["synthesis_delayed_exponential_tau"], step: 0.1 %></td>
          </tr>
          <tr>
            <td><%= f.label :synthesis_burst_default_age_gyr, "Burst default age (Gyr)" %></td>
            <td><%= f.number_field :synthesis_burst_default_age_gyr, value: @settings["synthesis_burst_default_age_gyr"], step: 0.1 %></td>
          </tr>
          <tr>
            <td><%= f.label :synthesis_burst_default_width_gyr, "Burst default width (Gyr)" %></td>
            <td><%= f.number_field :synthesis_burst_default_width_gyr, value: @settings["synthesis_burst_default_width_gyr"], step: 0.1 %></td>
          </tr>
          <tr>
            <td><%= f.label :synthesis_default_wavelength_min_nm, "Default wavelength min (nm)" %></td>
            <td><%= f.number_field :synthesis_default_wavelength_min_nm, value: @settings["synthesis_default_wavelength_min_nm"], step: 1 %></td>
          </tr>
          <tr>
            <td><%= f.label :synthesis_default_wavelength_max_nm, "Default wavelength max (nm)" %></td>
            <td><%= f.number_field :synthesis_default_wavelength_max_nm, value: @settings["synthesis_default_wavelength_max_nm"], step: 1 %></td>
          </tr>
          <tr>
            <td>Permit Celestial Coordinate Searches</td>
            <td>
              <label for="pipeline_config_synthesis_permit_celestial_coordinate_searches">
                <%= hidden_field_tag "pipeline_config[synthesis_permit_celestial_coordinate_searches]", "0" %>
                <%= check_box_tag "pipeline_config[synthesis_permit_celestial_coordinate_searches]",
                                  "1",
                                  ActiveModel::Type::Boolean.new.cast(@settings["synthesis_permit_celestial_coordinate_searches"]),
                                  id: "pipeline_config_synthesis_permit_celestial_coordinate_searches" %>
                enabled
              </label>
            </td>
          </tr>
          <tr>
            <td><%= f.label :synthesis_sdss_max_fetch_attempts, "SDSS max fetch attempts" %></td>
            <td><%= f.number_field :synthesis_sdss_max_fetch_attempts, value: @settings["synthesis_sdss_max_fetch_attempts"], min: 1, step: 1 %></td>
          </tr>
          <tr>
            <td><%= f.label :synthesis_sdss_base_backoff_seconds, "SDSS backoff base seconds" %></td>
            <td><%= f.number_field :synthesis_sdss_base_backoff_seconds, value: @settings["synthesis_sdss_base_backoff_seconds"], step: 0.1 %></td>
          </tr>
          <tr>
            <td><%= f.label :sdss_dataset_release, "SDSS dataset release" %></td>
            <td>
              <%= f.select :sdss_dataset_release,
                           options_for_select(PipelineConfig::SDSS_RELEASES, @settings["sdss_dataset_release"].to_s.upcase.presence || "DR19") %>
            </td>
          </tr>
          <tr>
            <td><%= f.label :mag_type, "Active magnitude type" %></td>
            <td>
              <%= f.select :mag_type,
                           options_for_select(PipelineConfig::MAG_TYPES, @settings["mag_type"].to_s.downcase.presence || "petrosian") %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="form-card">
      <h2>Grid Fit</h2>
      <table>
        <thead>
          <tr><th>Name</th><th>Value</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><%= f.label :grid_ages_gyr, "Ages (Gyr, comma-separated)" %></td>
            <td><%= f.text_field :grid_ages_gyr, value: Array(@settings["grid_ages_gyr"]).join(", ") %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_metallicities_z, "Metallicities Z (comma-separated)" %></td>
            <td><%= f.text_field :grid_metallicities_z, value: Array(@settings["grid_metallicities_z"]).join(", ") %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_sfh_models, "SFH models (comma-separated)" %></td>
            <td><%= f.text_field :grid_sfh_models, value: Array(@settings["grid_sfh_models"]).join(", ") %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_imf_types, "IMF types (comma-separated)" %></td>
            <td><%= f.text_field :grid_imf_types, value: Array(@settings["grid_imf_types"]).join(", ") %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_burst_ages_gyr, "Burst ages (Gyr, comma-separated)" %></td>
            <td><%= f.text_field :grid_burst_ages_gyr, value: Array(@settings["grid_burst_ages_gyr"]).join(", ") %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_age_bins_gyr, "Internal age bins for SFH weighting (Gyr)" %></td>
            <td><%= f.text_field :grid_age_bins_gyr, value: Array(@settings["grid_age_bins_gyr"]).join(", ") %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_imf_sample_size, "IMF sample size" %></td>
            <td><%= f.number_field :grid_imf_sample_size, value: @settings["grid_imf_sample_size"], min: 10, step: 10 %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_wavelength_min_nm, "Wavelength min (nm)" %></td>
            <td><%= f.number_field :grid_wavelength_min_nm, value: @settings["grid_wavelength_min_nm"], step: 1 %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_wavelength_max_nm, "Wavelength max (nm)" %></td>
            <td><%= f.number_field :grid_wavelength_max_nm, value: @settings["grid_wavelength_max_nm"], step: 1 %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_exponential_tau, "Exponential SFH tau (Gyr)" %></td>
            <td><%= f.number_field :grid_exponential_tau, value: @settings["grid_exponential_tau"], step: 0.1 %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_delayed_exponential_tau, "Delayed-exponential SFH tau (Gyr)" %></td>
            <td><%= f.number_field :grid_delayed_exponential_tau, value: @settings["grid_delayed_exponential_tau"], step: 0.1 %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_burst_width_gyr, "Burst width (Gyr)" %></td>
            <td><%= f.number_field :grid_burst_width_gyr, value: @settings["grid_burst_width_gyr"], step: 0.1 %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_sdss_max_fetch_attempts, "SDSS max fetch attempts" %></td>
            <td><%= f.number_field :grid_sdss_max_fetch_attempts, value: @settings["grid_sdss_max_fetch_attempts"], min: 1, step: 1 %></td>
          </tr>
          <tr>
            <td><%= f.label :grid_sdss_base_backoff_seconds, "SDSS backoff base seconds" %></td>
            <td><%= f.number_field :grid_sdss_base_backoff_seconds, value: @settings["grid_sdss_base_backoff_seconds"], step: 0.1 %></td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="form-card">
      <h2>Benchmark Run</h2>
      <table>
        <thead>
          <tr><th>Name</th><th>Value</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><%= f.label :calibration_progress_write_every, "Progress write frequency (steps)" %></td>
            <td><%= f.number_field :calibration_progress_write_every, value: @settings["calibration_progress_write_every"], min: 1, step: 1 %></td>
          </tr>
          <tr>
            <td>Enable Validation Gate Failure</td>
            <td>
              <label for="pipeline_config_calibration_enable_validation_gate">
                <%= hidden_field_tag "pipeline_config[calibration_enable_validation_gate]", "0" %>
                <%= check_box_tag "pipeline_config[calibration_enable_validation_gate]",
                                  "1",
                                  ActiveModel::Type::Boolean.new.cast(@settings["calibration_enable_validation_gate"]),
                                  id: "pipeline_config_calibration_enable_validation_gate" %>
                enabled
              </label>
            </td>
          </tr>
          <tr>
            <td><%= f.label :calibration_fast_ages_gyr, "Fast mode ages (Gyr, comma-separated)" %></td>
            <td><%= f.text_field :calibration_fast_ages_gyr, value: Array(@settings["calibration_fast_ages_gyr"]).join(", ") %></td>
          </tr>
          <tr>
            <td><%= f.label :calibration_fast_metallicities_z, "Fast mode metallicities (comma-separated)" %></td>
            <td><%= f.text_field :calibration_fast_metallicities_z, value: Array(@settings["calibration_fast_metallicities_z"]).join(", ") %></td>
          </tr>
          <tr>
            <td><%= f.label :calibration_fast_sfh_models, "Fast mode SFH models (comma-separated)" %></td>
            <td><%= f.text_field :calibration_fast_sfh_models, value: Array(@settings["calibration_fast_sfh_models"]).join(", ") %></td>
          </tr>
          <tr>
            <td><%= f.label :calibration_fast_imf_types, "Fast mode IMF types (comma-separated)" %></td>
            <td><%= f.text_field :calibration_fast_imf_types, value: Array(@settings["calibration_fast_imf_types"]).join(", ") %></td>
          </tr>
          <tr>
            <td><%= f.label :calibration_fast_burst_ages_gyr, "Fast mode burst ages (comma-separated)" %></td>
            <td><%= f.text_field :calibration_fast_burst_ages_gyr, value: Array(@settings["calibration_fast_burst_ages_gyr"]).join(", ") %></td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="config-save-row">
      <%= f.submit "Save Configuration" %>
    </div>
  <% end %>

  <div class="config-reset-row">
    <%= button_to "Reset To Defaults", reset_pipeline_config_path, method: :patch, class: "button-reset-defaults", form: { class: "inline-reset-form" }, data: { turbo_confirm: "Reset all pipeline settings to defaults?" } %>
  </div>
</div>
