<% processing = %w[pending running].include?(@grid_fit.status.to_s) %>
<% elapsed_start_seconds = [Time.current.to_i - @grid_fit.created_at.to_i, 0].max %>
<%
  runtime_seconds_value =
    if @grid_fit.runtime_seconds.present?
      @grid_fit.runtime_seconds.to_i
    elsif @grid_fit.status.to_s == "complete"
      [(@grid_fit.updated_at.to_i - @grid_fit.created_at.to_i), 0].max
    end
%>
<%
  status_label =
    if @grid_fit.status.to_s == "complete"
      total_seconds = runtime_seconds_value.to_i
      minutes = total_seconds / 60
      seconds = total_seconds % 60
      "completed in #{minutes} minutes, #{seconds} seconds"
    else
      @grid_fit.status
    end
%>
<% if processing %>
  <meta http-equiv="refresh" content="5">
<% end %>

<% if processing %>
  <style>
    .processing-banner {
      padding: 10px 14px;
      border: 1px solid #f59e0b;
      background: #2b1f07;
      color: #fde68a;
      border-radius: 6px;
      margin: 0 0 14px 0;
      font-weight: 600;
      animation: processing-pulse 1.5s ease-in-out infinite;
    }

    @keyframes processing-pulse {
      0% { opacity: 0.75; }
      50% { opacity: 1.0; }
      100% { opacity: 0.75; }
    }
  </style>

  <div class="processing-banner">
    Running parameter grid sweep...
    <span id="processing-elapsed" data-elapsed-seconds="<%= elapsed_start_seconds %>" style="margin-left: 8px; font-family: monospace;">(elapsed: 0s)</span>
  </div>

  <script>
    (function() {
      const elapsedEl = document.getElementById("processing-elapsed");
      if (!elapsedEl) return;

      let elapsedSeconds = parseInt(elapsedEl.dataset.elapsedSeconds || "0", 10);
      function formatElapsed(seconds) {
        const mins = Math.floor(seconds / 60);
        const secs = seconds % 60;
        if (mins > 0) return mins + "m " + secs + "s";
        return secs + "s";
      }

      elapsedEl.textContent = "(elapsed: " + formatElapsed(elapsedSeconds) + ")";
      setInterval(function() {
        elapsedSeconds += 1;
        elapsedEl.textContent = "(elapsed: " + formatElapsed(elapsedSeconds) + ")";
      }, 1000);
    })();
  </script>
<% end %>

<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h1 class="card-title"><%= @grid_fit.name.presence || "Grid Fit ##{@grid_fit.id}" %></h1>
      <p class="card-subtitle">Target information and grid sweep status.</p>
    </div>
  </div>
  <div class="cyberspace-panel-body">
    <p><strong>Status:</strong> <%= status_label %></p>
    <p><strong>Target:</strong> <%= @grid_fit.target_name.presence || "Unknown" %></p>
    <% if @grid_fit.status.to_s == "complete" %>
      <p><strong>Total runtime:</strong> <%= runtime_seconds_value %> seconds</p>
    <% end %>
    <p><strong>SDSS RA:</strong> <%= @grid_fit.sdss_ra %></p>
    <p><strong>SDSS Dec:</strong> <%= @grid_fit.sdss_dec %></p>
  </div>
</div>

<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h2 class="card-title">Grid Parameters</h2>
    </div>
  </div>
  <div class="cyberspace-panel-body" style="font-family: monospace;">
    <p><strong>ages:</strong> [0.01, 0.05, 0.1, 0.5, 1.0, 3.0, 5.0, 8.0, 10.0, 12.0] Gyr</p>
    <p><strong>metallicities:</strong> [0.0006, 0.0020, 0.0063, 0.0200, 0.0632]</p>
    <p><strong>sfh_models:</strong> [exponential, delayed_exponential, constant, burst]</p>
    <p><strong>imf_types:</strong> [kroupa, salpeter, chabrier]</p>
    <p><strong>Total combinations:</strong> 600</p>
  </div>
</div>

<% if @grid_fit.status.to_s == "complete" %>
  <div class="cyberspace-panel">
    <div class="card-header">
      <div>
        <h2 class="card-title">Best Fit</h2>
      </div>
    </div>
    <div class="cyberspace-panel-body">
      <p><strong>Best chi-squared:</strong> <%= @grid_fit.best_chi_squared ? format("%.6f", @grid_fit.best_chi_squared) : "-" %></p>
      <p><strong>Best age (Gyr):</strong> <%= @grid_fit.best_age_gyr %></p>
      <p><strong>Best metallicity (Z):</strong> <%= @grid_fit.best_metallicity_z %></p>
      <p><strong>Best SFH model:</strong> <%= @grid_fit.best_sfh_model %></p>
      <p><strong>Best IMF type:</strong> <%= @grid_fit.best_imf_type %></p>
    </div>
  </div>

  <% age_label =
       if @grid_fit.best_age_gyr.to_f < 0.1
         "very young"
       elsif @grid_fit.best_age_gyr.to_f < 1.0
         "young"
       elsif @grid_fit.best_age_gyr.to_f < 5.0
         "intermediate-age"
       else
         "old"
       end %>
  <% metallicity_label =
       if @grid_fit.best_metallicity_z.to_f < 0.01
         "formed from gas with fewer heavy elements than the Sun"
       elsif @grid_fit.best_metallicity_z.to_f <= 0.03
         "formed from gas with a heavy-element mix similar to the Sun"
       else
         "formed from gas with more heavy elements than the Sun"
       end %>
  <% age_reference_phrase =
       if @grid_fit.best_age_gyr.to_f < 1.0
         "Compared with older stellar populations (about 5 to 12 billion years), this best fit points to a younger population (about #{format('%.2f', @grid_fit.best_age_gyr)} billion years)."
       elsif @grid_fit.best_age_gyr.to_f < 5.0
         "Compared with very old stellar populations (about 10 to 12 billion years), this best fit points to a middle-aged population (about #{format('%.2f', @grid_fit.best_age_gyr)} billion years)."
       else
         "This best fit points to an old stellar population (about #{format('%.2f', @grid_fit.best_age_gyr)} billion years), consistent with long-lived, evolved stars."
       end %>
  <% sfh_phrase =
       case @grid_fit.best_sfh_model.to_s
       when "exponential" then "star birth was stronger in the past and then gradually slowed down"
       when "delayed_exponential" then "star birth ramped up to a peak and then gradually declined"
       when "constant" then "star birth has stayed at a fairly steady rate over time"
       when "burst" then "the light is better explained by one brief period of intense star birth than by continuous star birth"
       else "star formation history is uncertain"
       end %>
  <% fit_quality =
       if @grid_fit.best_chi_squared.to_f < 0.2
         "very strong"
       elsif @grid_fit.best_chi_squared.to_f < 1.0
         "strong"
       elsif @grid_fit.best_chi_squared.to_f < 5.0
         "moderate"
       else
         "weak"
       end %>

  <div class="cyberspace-panel">
    <div class="card-header">
      <div>
        <h2 class="card-title">What This Means</h2>
        <p class="card-subtitle">Plain-language interpretation of the best-fit parameters.</p>
      </div>
    </div>
    <div class="cyberspace-panel-body">
      <p>
        <strong><%= age_reference_phrase %></strong>
      </p>
      <p>
        The stars are best matched by a population that is <strong><%= metallicity_label %></strong>
        (heavy elements here means elements such as carbon, oxygen, and iron).
      </p>
      <p>
        The model suggests that <strong><%= sfh_phrase %></strong>.
      </p>
      <p>
        Fit confidence from this photometry-only run is <strong><%= fit_quality %></strong>
        (chi-squared <%= format("%.6f", @grid_fit.best_chi_squared) %>; lower is better).
      </p>
    </div>
  </div>
<% end %>

<% if @grid_fit.status.to_s == "failed" && @grid_fit.error_message.present? %>
  <div style="margin: 14px 0; padding: 10px 14px; border: 1px solid #ef4444; background: #2a0f12; color: #fecaca; border-radius: 6px;">
    <strong>Grid Fit Error:</strong>
    <%= @grid_fit.error_message %>
  </div>
<% end %>

<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h2 class="card-title">Ranked Results (Top 20)</h2>
    </div>
  </div>
  <div class="cyberspace-panel-body">
    <table>
      <thead>
        <tr>
          <th>Rank</th>
          <th>Chi-squared</th>
          <th>Age (Gyr)</th>
          <th>Metallicity (Z)</th>
          <th>SFH Model</th>
          <th>IMF Type</th>
        </tr>
      </thead>
      <tbody>
        <% @ranked_results.first(20).each_with_index do |row, idx| %>
          <tr>
            <td><%= idx + 1 %></td>
            <td><%= row["chi_squared"] ? format("%.6f", row["chi_squared"]) : "-" %></td>
            <td><%= row["age_gyr"] %></td>
            <td><%= row["metallicity_z"] %></td>
            <td><%= row["sfh_model"] %></td>
            <td><%= row["imf_type"] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="action-links">
  <%= link_to "Back to Grid Fits", grid_fits_path %>
</div>
