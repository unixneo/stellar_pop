<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h1 class="card-title">Galaxies</h1>
      <p class="card-subtitle">Manage local galaxy records and import catalog CSV files.</p>
    </div>
  </div>
  <div class="cyberspace-panel-body">
    <div class="galaxies-index-actions">
      <%= link_to "New Galaxy", new_galaxy_path, class: "primary-action-button" %>
    </div>

    <div class="form-card">
      <%= form_with url: galaxies_path, method: :get do %>
        <p>
          <label for="q">Search name/type</label>
          <input type="text" id="q" name="q" value="<%= @query %>" placeholder="e.g. M101, elliptical">
        </p>
        <p class="form-action-row"><%= submit_tag "Search", class: "galaxies-submit-button" %></p>
      <% end %>
    </div>

    <div class="form-card import-form-card">
      <%= form_with url: import_galaxies_path, method: :post, multipart: true, class: "import-galaxies-form" do %>
        <p class="file-chooser-row">
          <label for="csv_file">Import CSV</label>
          <input type="file" id="csv_file" name="csv_file" accept=".csv,text/csv">
          <span class="form-help">Upsert by name, fallback by RA/Dec match.</span>
        </p>
        <p class="form-action-row import-action-row"><%= submit_tag "Import CSV", class: "galaxies-submit-button import-csv-button" %></p>
      <% end %>
    </div>

    <div class="table-wrap">
      <% sort_link = lambda do |label, key|
           next_dir = (@sort == key && @dir == "asc") ? "desc" : "asc"
           indicator = @sort == key ? (@dir == "asc" ? " ▲" : " ▼") : ""
           link_to("#{label}#{indicator}", galaxies_path(q: @query, sort: key, dir: next_dir))
         end %>
      <table>
        <thead>
          <tr>
            <th><%= sort_link.call("Name", "name") %></th>
            <th><%= sort_link.call("Type", "galaxy_type") %></th>
            <th><%= sort_link.call("RA", "ra") %></th>
            <th><%= sort_link.call("Dec", "dec") %></th>
            <th><%= sort_link.call("u", "mag_u") %></th>
            <th><%= sort_link.call("g", "mag_g") %></th>
            <th><%= sort_link.call("r", "mag_r") %></th>
            <th><%= sort_link.call("i", "mag_i") %></th>
            <th><%= sort_link.call("z", "mag_z") %></th>
            <th><%= sort_link.call("SDSS DR", "sdss_dr") %></th>
            <th><%= sort_link.call("Source", "source_catalog") %></th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @galaxies.each do |galaxy| %>
            <tr>
              <td><%= link_to galaxy.name, galaxy_path(galaxy) %></td>
              <td><%= galaxy.galaxy_type %></td>
              <td><%= galaxy.ra %></td>
              <td><%= galaxy.dec %></td>
              <td><%= galaxy.mag_u %></td>
              <td><%= galaxy.mag_g %></td>
              <td><%= galaxy.mag_r %></td>
              <td><%= galaxy.mag_i %></td>
              <td><%= galaxy.mag_z %></td>
              <td><%= galaxy.sdss_dr %></td>
              <td><%= galaxy.source_catalog %></td>
              <td>
                <%= link_to "Edit", edit_galaxy_path(galaxy) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
