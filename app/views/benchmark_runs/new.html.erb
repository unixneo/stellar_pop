<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h1 class="card-title">New Benchmark Run</h1>
      <p class="card-subtitle">Run published-science benchmark checks against the current pipeline.</p>
    </div>
  </div>
  <div class="cyberspace-panel-body">
    <div class="form-card">
      <p><strong>Active SDSS dataset:</strong> <code><%= @active_sdss_release %></code></p>
    </div>
    <%= form_with model: @benchmark_run, local: true, data: { turbo: false } do |f| %>
      <div class="form-card">
        <p>
          <%= f.label :name, "Benchmark run name" %>
          <%= f.text_field :name, placeholder: "auto-generated if blank" %>
        </p>
      </div>

      <div class="form-card" style="font-family: monospace;">
        <p><strong>Benchmark target for this run:</strong></p>
        <p class="form-help">
          <%= @allow_multi_benchmark_targets ? "Select one or more targets from the active SDSS dataset release." : "Select exactly one target from the active SDSS dataset release." %>
        </p>
        <p class="form-help" style="margin-top: 4px;">Color legend: green = high, yellow = medium, red = low.</p>

        <table id="benchmark-targets-table">
          <thead>
            <tr>
              <th><%= link_to "Select", new_benchmark_run_path(request.query_parameters.merge(sort: "select", dir: (@sort == "select" && @dir == "asc") ? "desc" : "asc")) %></th>
              <th><%= link_to "Name", new_benchmark_run_path(request.query_parameters.merge(sort: "name", dir: (@sort == "name" && @dir == "asc") ? "desc" : "asc")) %></th>
              <th><%= link_to "Type", new_benchmark_run_path(request.query_parameters.merge(sort: "type", dir: (@sort == "type" && @dir == "asc") ? "desc" : "asc")) %></th>
              <th><%= link_to "OID Match", new_benchmark_run_path(request.query_parameters.merge(sort: "oid_match", dir: (@sort == "oid_match" && @dir == "asc") ? "desc" : "asc")) %></th>
              <th style="text-align: center;"><%= link_to "Expected Age (Gyr)", new_benchmark_run_path(request.query_parameters.merge(sort: "age", dir: (@sort == "age" && @dir == "asc") ? "desc" : "asc")) %></th>
              <th style="text-align: center;"><%= link_to "Expected Metallicity (Z)", new_benchmark_run_path(request.query_parameters.merge(sort: "metallicity", dir: (@sort == "metallicity" && @dir == "asc") ? "desc" : "asc")) %></th>
              <th style="text-align: center;"><%= link_to "Expected Stellar Mass (M☉)", new_benchmark_run_path(request.query_parameters.merge(sort: "stellar_mass", dir: (@sort == "stellar_mass" && @dir == "asc") ? "desc" : "asc")) %></th>
            </tr>
          </thead>
          <tbody>
            <% @benchmarks.each do |benchmark| %>
              <% dq = benchmark[:data_quality] || {} %>
              <% id_quality = dq[:id_match_quality].to_s %>
              <% redshift_conf = dq[:redshift_confidence].to_s %>
              <% eligible = !!dq[:benchmark_eligible] %>
              <% sdss_status = Galaxy.find_by(name: benchmark[:name], sdss_dr: @active_sdss_release)&.sdss_status %>
              <% id_quality_class =
                   if id_quality == "exact_objid"
                     "quality-high"
                   elsif id_quality == "coord_validated"
                     "quality-medium"
                   else
                     "quality-low"
                   end %>
              <tr>
                <td data-sort="<%= Array(params[:benchmark_keys]).map(&:to_s).include?(benchmark[:key].to_s) ? 1 : 0 %>">
                  <%= check_box_tag "benchmark_keys[]",
                                    benchmark[:key],
                                    Array(params[:benchmark_keys]).map(&:to_s).include?(benchmark[:key].to_s),
                                    class: "single-benchmark-check",
                                    id: "benchmark_key_#{benchmark[:key]}" %>
                </td>
                <td data-sort="<%= benchmark[:name].to_s.downcase %>"><%= benchmark[:name] %></td>
                <td data-sort="<%= benchmark[:type].to_s.downcase %>"><%= benchmark[:type] %></td>
                <td class="quality-cell" style="background-color: <%= sdss_status == 'confirmed' ? '#2d6a2d' : (sdss_status == 'bad_photometry' ? '#8b0000' : '#8b7000') %>;" data-sort="<%= id_quality == "exact_objid" ? 3 : (id_quality == "coord_validated" ? 2 : 1) %>"></td>
                <td style="text-align: center;" data-sort="<%= benchmark.dig(:expected, :age_gyr_min).to_f %>"><%= benchmark.dig(:expected, :age_gyr_min).nil? ? "-" : format("%.3f", benchmark.dig(:expected, :age_gyr_min).to_f) %></td>
                <td style="text-align: center;" data-sort="<%= benchmark.dig(:expected, :metallicity_z_min).to_f %>"><%= benchmark.dig(:expected, :metallicity_z_min).nil? ? "-" : format("%.3f", benchmark.dig(:expected, :metallicity_z_min).to_f) %></td>
                <td style="text-align: center;" data-sort="<%= benchmark.dig(:expected, :stellar_mass_min).to_f %>"><%= benchmark.dig(:expected, :stellar_mass_min).nil? ? "-" : format("%.3e", benchmark.dig(:expected, :stellar_mass_min).to_f) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="form-card">
        <p>
          <label style="display: inline-flex; align-items: center; gap: 8px;">
            <%= check_box_tag :fast_mode, "1", true %>
            <strong>Fast mode</strong> (reduced grid for quicker benchmark turnaround)
          </label>
        </p>
        <p class="form-help">
          Fast mode reduces the number of model combinations per benchmark to speed up execution.
        </p>
      </div>

      <div class="form-card">
        <p><%= f.submit "Start Benchmark" %></p>
      </div>
    <% end %>
  </div>
</div>

<div class="action-links">
  <%= link_to "Back to Benchmark Runs", benchmark_runs_path %>
</div>

<script>
  function initBenchmarkRunForm() {
    const checks = document.querySelectorAll(".single-benchmark-check");
    const allowMultiple = <%= @allow_multi_benchmark_targets ? "true" : "false" %>;
    if (allowMultiple) return;

    checks.forEach(function(check) {
      if (check.dataset.singleBound === "1") return;
      check.dataset.singleBound = "1";
      check.addEventListener("change", function() {
        if (!check.checked) return;
        checks.forEach(function(other) {
          if (other !== check) other.checked = false;
        });
      });
    });

  }

  document.addEventListener("turbo:load", initBenchmarkRunForm);
  document.addEventListener("DOMContentLoaded", initBenchmarkRunForm);
</script>
