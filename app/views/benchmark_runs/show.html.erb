<% processing = %w[pending running].include?(@benchmark_run.status.to_s) %>
<% elapsed_start_seconds = [Time.current.to_i - @benchmark_run.created_at.to_i, 0].max %>
<% result_mode = @result.is_a?(Hash) ? @result["mode"].to_s : "" %>
<%
  inferred_mode = nil
  if result_mode.blank? && processing
    config = PipelineConfig.current
    total_steps = @benchmark_run.progress_total.to_i
    benchmark_count =
      begin
        step_text = @benchmark_run.current_step.to_s
        if (match = step_text.match(/Benchmark\s+\d+\/(\d+):/))
          match[1].to_i
        elsif @result.is_a?(Hash) && @result["benchmarks"].is_a?(Array)
          @result["benchmarks"].size
        else
          0
        end
      rescue StandardError
        0
      end

    if total_steps.positive? && benchmark_count.positive?
      per_benchmark = total_steps / benchmark_count

      full_ages = config.float_array("grid_ages_gyr")
      full_metallicities = config.float_array("grid_metallicities_z")
      full_imf_types = config.string_array("grid_imf_types")
      full_sfh_models = config.string_array("grid_sfh_models")
      full_burst_ages = config.float_array("grid_burst_ages_gyr")
      full_non_burst = full_sfh_models.reject { |name| name == "burst" }.size
      full_effective_sfh = full_non_burst + full_burst_ages.size
      full_combinations = full_ages.size * full_metallicities.size * full_imf_types.size * full_effective_sfh

      fast_ages = config.float_array("calibration_fast_ages_gyr")
      fast_metallicities = config.float_array("calibration_fast_metallicities_z")
      fast_imf_types = config.string_array("calibration_fast_imf_types")
      fast_sfh_models = config.string_array("calibration_fast_sfh_models")
      fast_burst_ages = config.float_array("calibration_fast_burst_ages_gyr")
      fast_non_burst = fast_sfh_models.reject { |name| name == "burst" }.size
      fast_effective_sfh = fast_non_burst + fast_burst_ages.size
      fast_combinations = fast_ages.size * fast_metallicities.size * fast_imf_types.size * fast_effective_sfh

      inferred_mode =
        if per_benchmark == fast_combinations
          "fast"
        elsif per_benchmark == full_combinations
          "full"
        end
    end
  end
%>
<%
  run_mode_label =
    if result_mode.present?
      result_mode
    elsif inferred_mode.present?
      "#{inferred_mode} (in progress)"
    elsif processing
      "in progress"
    else
      "-"
    end
%>
<%
  status_label =
    case @benchmark_run.status.to_s
    when "complete"
      @benchmark_run.runtime_seconds.present? ? "completed in #{@benchmark_run.runtime_seconds} seconds" : "complete"
    when "failed"
      @benchmark_run.runtime_seconds.present? ? "failed after #{@benchmark_run.runtime_seconds} seconds" : "failed"
    else
      @benchmark_run.status
    end
%>
<%
  gate_enabled = ActiveModel::Type::Boolean.new.cast(PipelineConfig.current.fetch("calibration_enable_validation_gate"))
  result_benchmarks = @result.is_a?(Hash) ? Array(@result["benchmarks"]) : []
  skipped_benchmarks =
    result_benchmarks.select do |row|
      dq = row["data_quality"] || {}
      eligible = ActiveModel::Type::Boolean.new.cast(dq["benchmark_eligible"])
      top_results = Array(row["top_results"])
      !eligible && top_results.empty?
    end
%>
<% if processing %>
  <% singular_benchmark = @benchmark_run.current_step.to_s.match?(/Benchmark\s+\d+\/1:/) %>
  <% banner_mode = result_mode.presence || inferred_mode.presence || "configured" %>
  <meta http-equiv="refresh" content="5">
  <div class="processing-banner" style="padding: 10px 14px; border: 1px solid #f59e0b; background: #2b1f07; color: #fde68a; border-radius: 6px; margin: 0 0 14px 0; font-weight: 600;">
    Running benchmark checks for selected reference <%= singular_benchmark ? "galaxy" : "galaxies" %> (<%= banner_mode %> grid sweep + chi-squared ranking)...
    <span id="processing-elapsed" data-elapsed-seconds="<%= elapsed_start_seconds %>" style="margin-left: 8px; font-family: monospace;">(elapsed: 0s)</span>
  </div>

  <script>
    (function() {
      const elapsedEl = document.getElementById("processing-elapsed");
      if (!elapsedEl) return;

      let elapsedSeconds = parseInt(elapsedEl.dataset.elapsedSeconds || "0", 10);
      function formatElapsed(seconds) {
        const mins = Math.floor(seconds / 60);
        const secs = seconds % 60;
        if (mins > 0) return mins + "m " + secs + "s";
        return secs + "s";
      }

      elapsedEl.textContent = "(elapsed: " + formatElapsed(elapsedSeconds) + ")";
      setInterval(function() {
        elapsedSeconds += 1;
        elapsedEl.textContent = "(elapsed: " + formatElapsed(elapsedSeconds) + ")";
      }, 1000);
    })();
  </script>
<% end %>

<style>
  .benchmark-name-col {
    width: 210px;
  }
</style>

<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h1 class="card-title"><%= @benchmark_run.name %></h1>
      <p class="card-subtitle">Benchmark run status and results.</p>
    </div>
    <% if processing %>
      <%= button_to "Cancel Benchmark Run",
                    cancel_benchmark_run_path(@benchmark_run),
                    method: :post,
                    data: { turbo_confirm: "Cancel this benchmark run?" },
                    class: "benchmark-cancel-button",
                    form: { class: "benchmark-cancel-form" } %>
    <% end %>
  </div>
  <div class="cyberspace-panel-body">
    <p><strong>Active SDSS dataset:</strong> <code><%= @active_sdss_release %></code></p>
    <table>
      <thead>
        <tr>
          <th class="benchmark-name-col">Name</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="benchmark-name-col">Status</td><td><%= status_label %></td></tr>
        <tr><td class="benchmark-name-col">Run mode</td><td><%= run_mode_label %></td></tr>
        <% if @benchmark_run.runtime_seconds.present? %>
          <tr><td class="benchmark-name-col">Runtime</td><td><%= @benchmark_run.runtime_seconds %> seconds</td></tr>
        <% end %>
        <% if @benchmark_run.error_message.present? %>
          <tr><td class="benchmark-name-col">Error</td><td><%= @benchmark_run.error_message %></td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%
  total = @benchmark_run.progress_total.to_i
  completed = [@benchmark_run.progress_completed.to_i, total].min
  progress_percent = total.positive? ? ((completed.to_f / total) * 100.0) : 0.0
  elapsed_seconds = [Time.current.to_i - @benchmark_run.created_at.to_i, 0].max
  eta_seconds =
    if processing && completed.positive? && total > completed
      ((elapsed_seconds.to_f / completed) * (total - completed)).round
    end
%>
<% if processing || total.positive? %>
  <div class="cyberspace-panel">
    <div class="card-header">
      <div>
        <h2 class="card-title">Benchmark Progress</h2>
        <p class="card-subtitle">Live progress for benchmark sweep execution.</p>
      </div>
    </div>
    <div class="cyberspace-panel-body" style="font-family: monospace;">
      <table style="margin-bottom: 15px;">
        <thead>
          <tr>
            <th class="benchmark-name-col">Name</th>
            <th>Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="benchmark-name-col">Current step</td><td><%= @benchmark_run.current_step.presence || "-" %></td></tr>
          <tr><td class="benchmark-name-col">Completed</td><td><%= completed %> / <%= total %> (<%= format("%.1f", progress_percent) %>%)</td></tr>
        </tbody>
      </table>
      <% if eta_seconds %>
        <p><strong>Estimated remaining:</strong> <%= eta_seconds %> seconds</p>
      <% elsif processing %>
        <p><strong>Estimated remaining:</strong> computing...</p>
      <% end %>
      <div style="height: 10px; border: 1px solid #334155; border-radius: 999px; overflow: hidden; background: rgba(2, 6, 23, 0.85);">
        <div style="height: 100%; width: <%= progress_percent %>%; background: linear-gradient(90deg, #0ea5e9, #22d3ee);"></div>
      </div>
    </div>
  </div>
<% end %>

<% if @result.present? %>
  <% if skipped_benchmarks.any? %>
    <div style="padding: 12px 14px; border: 1px solid #ef4444; background: #2d0a0a; color: #fecaca; border-radius: 6px; margin: 0 0 14px 0;">
      <strong>Warning:</strong>
      <%= skipped_benchmarks.size %> benchmark(s) were marked ineligible and effectively skipped by data-quality gates (no ranked-fit sweep was executed).
      <br>
      <span style="font-family: monospace;">
        affected: <%= skipped_benchmarks.map { |row| row["name"] }.join(", ") %>
      </span>
    </div>
  <% elsif !gate_enabled && result_benchmarks.any? %>
    <div style="padding: 12px 14px; border: 1px solid #f59e0b; background: #2b1f07; color: #fde68a; border-radius: 6px; margin: 0 0 14px 0;">
      <strong>Validation gates disabled:</strong> benchmark eligibility and failure gates are turned off in configuration.
    </div>
  <% end %>

  <% summary = @result["summary"] || {} %>
  <% run_mode = @result["mode"].to_s.presence || "full" %>
  <div class="cyberspace-panel">
    <div class="card-header">
      <div><h2 class="card-title">Summary</h2></div>
    </div>
    <div class="cyberspace-panel-body" style="font-family: monospace;">
      <table>
        <thead>
          <tr>
            <th class="benchmark-name-col">Name</th>
            <th>Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="benchmark-name-col">mode</td><td><%= run_mode %></td></tr>
          <tr><td class="benchmark-name-col">total</td><td><%= summary["total"] %></td></tr>
          <tr><td class="benchmark-name-col">pass</td><td><%= summary["pass"] %></td></tr>
          <tr><td class="benchmark-name-col">warn</td><td><%= summary["warn"] %></td></tr>
          <tr><td class="benchmark-name-col">fail</td><td><%= summary["fail"] %></td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <% Array(@result["benchmarks"]).each do |benchmark| %>
    <div class="cyberspace-panel">
      <div class="card-header">
        <div>
          <h2 class="card-title"><%= benchmark["name"] %> (<%= benchmark["type"] %>)</h2>
          <p class="card-subtitle">verdict: <strong><%= benchmark["verdict"] %></strong></p>
        </div>
      </div>
      <div class="cyberspace-panel-body">
        <% best = benchmark["best_fit"] || {} %>
        <% expected = benchmark["expected"] || {} %>
        <% references = Array(benchmark["references"]) %>
        <% benchmark_notes = benchmark["notes"].to_s %>
        <% benchmark_type = benchmark["benchmark_type"].to_s %>
        <% mass_cmp = benchmark["stellar_mass_comparison"] || {} %>
        <% best_age = best["age_gyr"].to_f %>
        <% best_z = best["metallicity_z"].to_f %>
        <% age_min = expected["age_gyr_min"].to_f %>
        <% age_max = expected["age_gyr_max"].to_f %>
        <% z_min = expected["metallicity_z_min"].to_f %>
        <% z_max = expected["metallicity_z_max"].to_f %>
        <% obs_counts = expected["observation_counts"] || {} %>
        <% agg_note = expected["aggregation_note"].to_s %>
        <% age_comparison =
             if best_age < age_min
               "too young"
             elsif best_age > age_max
               "too old"
             else
               "within expected range"
             end %>
        <% z_comparison =
             if best_z < z_min
               "too low"
             elsif best_z > z_max
               "too high"
             else
               "within expected range"
             end %>

        <% if benchmark_type.present? %>
          <p><strong>Benchmark type:</strong> <%= benchmark_type %></p>
        <% end %>
        <% if benchmark_notes.present? %>
          <p><strong>Notes:</strong> <%= benchmark_notes %></p>
        <% end %>
        <% dq = benchmark["data_quality"] || {} %>
        <div class="form-card">
          <h3 style="margin: 0 0 8px;">Data Quality</h3>
          <table>
            <thead>
              <tr>
                <th>Metric</th>
                <th>Value</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>ID match quality</td><td><%= dq["id_match_quality"] || "-" %></td></tr>
              <tr><td>ID match distance (arcsec)</td><td><%= dq["id_match_distance_arcsec"] || "-" %></td></tr>
              <tr><td>Redshift source</td><td><%= dq["redshift_source"] || "-" %></td></tr>
              <tr><td>Redshift confidence</td><td><%= dq["redshift_confidence"] || "-" %></td></tr>
              <tr><td>Band errors present</td><td><%= dq["has_band_errors"] %></td></tr>
              <tr><td>Redshift error present</td><td><%= dq["has_redshift_error"] %></td></tr>
              <tr><td>Benchmark eligible</td><td><%= dq["benchmark_eligible"] %></td></tr>
              <tr><td>Eligibility notes</td><td><%= Array(dq["reasons"]).join(", ").presence || "-" %></td></tr>
            </tbody>
          </table>
        </div>

        <div class="form-card">
          <h3 style="margin: 0 0 8px;">Measured vs Observational</h3>
          <table>
            <thead>
              <tr>
                <th>Metric</th>
                <th>Measured</th>
                <th>Observational</th>
                <th>Assessment</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Age (Gyr)</td>
                <td><%= best["age_gyr"] %></td>
                <td><%= age_min %>-<%= age_max %></td>
                <td><%= age_comparison %></td>
              </tr>
              <tr>
                <td>Metallicity (Z)</td>
                <td><%= best["metallicity_z"] %></td>
                <td><%= z_min %>-<%= z_max %></td>
                <td><%= z_comparison %></td>
              </tr>
              <tr>
                <td>Stellar mass (M☉)</td>
                <% if mass_cmp["sps_stellar_mass"] && mass_cmp["observed_stellar_mass"] %>
                  <td><%= format("%.3e", mass_cmp["sps_stellar_mass"].to_f) %></td>
                  <td><%= format("%.3e", mass_cmp["observed_stellar_mass"].to_f) %></td>
                  <% ratio = mass_cmp["ratio_sps_to_observed"].to_f %>
                  <td><%= ratio.nan? ? "unavailable" : format("%.3f", ratio) %>x</td>
                <% else %>
                  <td>-</td>
                  <td>-</td>
                  <td>unavailable</td>
                <% end %>
              </tr>
              <tr>
                <td>Observational source counts</td>
                <td>-</td>
                <td>
                  age=<%= obs_counts["age_gyr"] || 0 %>,
                  metallicity=<%= obs_counts["metallicity_z"] || 0 %>,
                  stellar_mass=<%= obs_counts["stellar_mass"] || 0 %>
                </td>
                <td>by SDSS ObjID</td>
              </tr>
              <tr>
                <td>Aggregation method</td>
                <td>-</td>
                <td><%= agg_note.presence || "-" %></td>
                <td>-</td>
              </tr>
            </tbody>
          </table>
        </div>
        <% checks = benchmark["checks"] || {} %>
        <% ineligible = !ActiveModel::Type::Boolean.new.cast(dq["benchmark_eligible"]) %>
        <% no_ranked_fits = Array(benchmark["top_results"]).empty? %>
        <% if ineligible && no_ranked_fits %>
          <div style="padding: 10px 12px; border: 1px solid #ef4444; background: #2d0a0a; color: #fecaca; border-radius: 6px; margin: 0 0 12px 0; font-weight: 600;">
            Benchmark fit sweep was skipped due to failed data-quality eligibility.
          </div>
        <% end %>
        <p style="font-family: monospace;">checks: age_ok=<%= checks["age_ok"] %>, metallicity_ok=<%= checks["metallicity_ok"] %>, chi_squared_ok=<%= checks["chi_squared_ok"] %>, data_quality_ok=<%= checks["data_quality_ok"] %></p>
        <% diagnostics = benchmark["photometric_diagnostics"] || {} %>
        <% colors = diagnostics["colors"] || {} %>
        <% if colors.present? %>
          <div class="form-card">
            <h3 style="margin: 0 0 8px;">Photometric Diagnostics (Best Fit)</h3>
            <table>
              <thead>
                <tr>
                  <th>Color</th>
                  <th>Observed</th>
                  <th>Synthetic</th>
                  <th>Delta (syn-obs)</th>
                </tr>
              </thead>
              <tbody>
                <% colors.each do |label, values| %>
                  <tr>
                    <td><%= label %></td>
                    <td><%= format("%.4f", values["observed"].to_f) %></td>
                    <td><%= format("%.4f", values["synthetic"].to_f) %></td>
                    <td><%= format("%.4f", values["delta"].to_f) %></td>
                  </tr>
                <% end %>
                <tr>
                  <td>chi_squared</td>
                  <td colspan="2">threshold ≤ <%= format("%.3f", diagnostics["chi_squared_pass_max"].to_f) %></td>
                  <td><%= format("%.6f", diagnostics["chi_squared"].to_f) %></td>
                </tr>
              </tbody>
            </table>
          </div>
        <% end %>
        <% if references.any? %>
          <p><strong>References:</strong></p>
          <ul>
            <% references.each do |ref| %>
              <li><%= ref %></li>
            <% end %>
          </ul>
        <% end %>

        <details>
          <summary>Top 10 ranked fits</summary>
          <div class="table-wrap" style="margin-top: 8px;">
            <table>
              <thead>
                <tr>
                  <th>Rank</th>
                  <th>Chi2</th>
                  <th>Age</th>
                  <th>Z</th>
                  <th>SFH</th>
                  <th>Burst Age</th>
                  <th>IMF</th>
                </tr>
              </thead>
              <tbody>
                <% Array(benchmark["top_results"]).first(10).each_with_index do |row, idx| %>
                  <tr>
                    <td><%= idx + 1 %></td>
                    <td><%= row["chi_squared"] ? format("%.6f", row["chi_squared"]) : "-" %></td>
                    <td><%= row["age_gyr"] %></td>
                    <td><%= row["metallicity_z"] %></td>
                    <td><%= row["sfh_model"] %></td>
                    <td><%= row["burst_age_gyr"] || "-" %></td>
                    <td><%= row["imf_type"] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </details>
      </div>
    </div>
  <% end %>
<% end %>

<div class="run-show-actions">
  <div class="action-links benchmark-run-back-link">
    <%= link_to "Back to Benchmark Runs", benchmark_runs_path, class: "benchmark-new-button" %>
  </div>
  <% if %w[pending running].include?(@benchmark_run.status.to_s) %>
    <span class="delete-disabled-note">Delete disabled while benchmark run is pending/running.</span>
  <% else %>
    <%= button_to "Delete Benchmark Run",
                  benchmark_run_path(@benchmark_run),
                  method: :delete,
                  class: "danger-button",
                  form: { class: "danger-button-form" },
                  data: { turbo_confirm: "Delete this benchmark run permanently?" } %>
  <% end %>
</div>
