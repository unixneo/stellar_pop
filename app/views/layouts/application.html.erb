<!DOCTYPE html>
<html>
  <head>
    <title>StellarPop</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= favicon_link_tag "/favicon.svg", rel: "icon", type: "image/svg+xml" %>
    <link rel="shortcut icon" href="/favicon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "stellar_pop", "data-turbo-track": "reload" %>
  </head>

  <body>
    <header class="page-header">
      <div class="header-bar">
        <div class="header-brand">
          <%= image_tag "/favicon.svg", alt: "StellarPop logo", class: "header-logo" %>
          <h1>StellarPop</h1>
        </div>
        <div class="header-nav-meta">
          <nav class="nav-links">
            <%= link_to "Runs", synthesis_runs_path %>
            <%= link_to "New Run", new_synthesis_run_path %>
            <%= link_to "Run Test", seed_test_synthesis_runs_path %>
            <%= link_to "Grid Fits", grid_fits_path %>
            <%= link_to "Benchmarks", benchmark_runs_path %>
            <%= link_to "Config", edit_pipeline_config_path %>
          </nav>
          <span
            class="sidekiq-indicator <%= sidekiq_online? ? 'sidekiq-online' : 'sidekiq-offline' %>"
            title="Sidekiq <%= sidekiq_online? ? 'online' : 'offline' %>"
            aria-label="Sidekiq <%= sidekiq_online? ? 'online' : 'offline' %>"
          ></span>
          <span class="app-version-badge"><%= app_version_label %></span>
        </div>
      </div>
    </header>
    <main>
      <%= yield %>
    </main>
  </body>
</html>
