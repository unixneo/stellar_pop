<% processing = %w[pending running].include?(@synthesis_run.status.to_s) %>
<% elapsed_start_seconds = [Time.current.to_i - @synthesis_run.created_at.to_i, 0].max %>
<%
  runtime_seconds_value =
    if @synthesis_run.status.to_s == "complete"
      [(@synthesis_run.updated_at.to_i - @synthesis_run.created_at.to_i), 0].max
    end
%>
<%
  status_label =
    if @synthesis_run.status.to_s == "complete"
      total_seconds = runtime_seconds_value.to_i
      "completed in #{total_seconds} seconds"
    else
      @synthesis_run.status
    end
%>
<% processing_message =
     if @synthesis_run.status.to_s == "pending"
       "Loading stellar libraries and preparing synthesis pipeline..."
     else
       "Processing synthesis pipeline..."
     end %>
<% target_name = @synthesis_run.galaxy&.name.presence || @synthesis_run.sdss_object_name.presence %>
<% if processing %>
  <meta http-equiv="refresh" content="5">
<% end %>

<% if processing %>
  <style>
    .processing-banner {
      padding: 10px 14px;
      border: 1px solid #f59e0b;
      background: #2b1f07;
      color: #fde68a;
      border-radius: 6px;
      margin: 0 0 14px 0;
      font-weight: 600;
      animation: processing-pulse 1.5s ease-in-out infinite;
    }

    @keyframes processing-pulse {
      0% { opacity: 0.75; }
      50% { opacity: 1.0; }
      100% { opacity: 0.75; }
    }
  </style>

  <div class="processing-banner">
    <%= processing_message %>
    <span id="processing-elapsed" data-elapsed-seconds="<%= elapsed_start_seconds %>" style="margin-left: 8px; font-family: monospace;">(elapsed: 0s)</span>
  </div>

  <script>
    (function() {
      const elapsedEl = document.getElementById("processing-elapsed");
      if (!elapsedEl) return;

      let elapsedSeconds = parseInt(elapsedEl.dataset.elapsedSeconds || "0", 10);
      function formatElapsed(seconds) {
        const mins = Math.floor(seconds / 60);
        const secs = seconds % 60;
        if (mins > 0) return mins + "m " + secs + "s";
        return secs + "s";
      }

      elapsedEl.textContent = "(elapsed: " + formatElapsed(elapsedSeconds) + ")";
      setInterval(function() {
        elapsedSeconds += 1;
        elapsedEl.textContent = "(elapsed: " + formatElapsed(elapsedSeconds) + ")";
      }, 1000);
    })();
  </script>
<% end %>

<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h1 class="card-title">
        <%= @synthesis_run.name.presence || "Synthesis Run ##{@synthesis_run.id}" %><%= target_name.present? ? " — #{target_name}" : "" %>
      </h1>
      <p class="card-subtitle">Run parameters and current synthesis status.</p>
    </div>
  </div>
  <div class="cyberspace-panel-body">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Status</td><td><%= status_label %></td></tr>
        <tr><td>IMF type</td><td><%= @synthesis_run.imf_type %></td></tr>
        <tr><td>Spectra model</td><td><%= @synthesis_run.spectra_model %></td></tr>
        <tr><td>Age (Gyr)</td><td><%= @synthesis_run.age_gyr %></td></tr>
        <tr><td>Metallicity (Z)</td><td><%= @synthesis_run.metallicity_z %></td></tr>
        <tr><td>Wavelength range</td><td><%= @synthesis_run.wavelength_min %>-<%= @synthesis_run.wavelength_max %> nm</td></tr>
        <tr><td>SFH model</td><td><%= @synthesis_run.sfh_model %></td></tr>
        <% if @synthesis_run.sfh_model.to_s == "burst" %>
          <tr><td>Burst age (Gyr)</td><td><%= @synthesis_run.burst_age_gyr %></td></tr>
          <tr><td>Burst width (Gyr)</td><td><%= @synthesis_run.burst_width_gyr %></td></tr>
        <% end %>
        <tr><td>SDSS RA</td><td><%= @synthesis_run.sdss_ra %></td></tr>
        <tr><td>SDSS Dec</td><td><%= @synthesis_run.sdss_dec %></td></tr>
        <% if @synthesis_run.sdss_object_name.present? %>
          <tr><td>SDSS target</td><td><%= @synthesis_run.sdss_object_name %></td></tr>
        <% end %>
        <% if !@synthesis_run.chi_squared.nil? %>
          <tr><td>Chi-squared</td><td><%= format("%.6f", @synthesis_run.chi_squared) %></td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<% spectra_library_label =
     if @synthesis_run.spectra_model.to_s == "planck"
       "Planck blackbody"
     else
       "BaSeL 3.1 (Westera et al. 2002)"
     end %>
<% imf_label =
     if @synthesis_run.imf_type.to_s == "salpeter"
       "Salpeter (1955)"
     elsif @synthesis_run.imf_type.to_s == "chabrier"
       "Chabrier (2003)"
     else
       "Kroupa (2001) piecewise power law"
     end %>
<% sfh_label =
     case @synthesis_run.sfh_model.to_s
     when "exponential" then "Exponential decay"
     when "delayed_exponential" then "Delayed exponential"
     when "burst" then "Burst"
     else "Constant"
     end %>
<% mist_selected_feh = StellarPop::KnowledgeSources::MistIsochrone.nearest_feh_for_metallicity(@synthesis_run.metallicity_z.to_f) %>

<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h2 class="card-title">Pipeline Configuration<%= target_name.present? ? " — #{target_name}" : "" %></h2>
    </div>
  </div>
  <div class="cyberspace-panel-body" style="font-family: monospace;">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Spectra library</td><td><%= spectra_library_label %></td></tr>
        <tr><td>IMF</td><td><%= imf_label %></td></tr>
        <tr><td>Isochrone weighting</td><td>MIST v1.2 (Choi et al. 2016)</td></tr>
        <tr><td>MIST selected [Fe/H] bin</td><td><%= format("%.2f", mist_selected_feh) %></td></tr>
        <tr><td>SFH model</td><td><%= sfh_label %></td></tr>
        <tr><td>Chi-squared method</td><td>SDSS ugriz filter convolution (Fukugita et al. 1996)</td></tr>
      </tbody>
    </table>
  </div>
</div>

<% if @synthesis_run.status.to_s == "failed" && @synthesis_run.error_message.present? %>
  <div style="margin: 14px 0; padding: 10px 14px; border: 1px solid #ef4444; background: #2a0f12; color: #fecaca; border-radius: 6px;">
    <strong>Pipeline Error:</strong>
    <%= @synthesis_run.error_message %>
  </div>
<% end %>
<% if @synthesis_run.status.to_s == "complete" && @synthesis_run.error_message.present? %>
  <div style="margin: 14px 0; padding: 10px 14px; border: 1px solid #475569; background: #111827; color: #cbd5e1; border-radius: 6px;">
    <strong>Note:</strong>
    <%= @synthesis_run.error_message %>
  </div>
<% end %>

<% if @spectrum_result.present? %>
  <% wavelengths = JSON.parse(@spectrum_result.wavelength_data || "[]") rescue [] %>
  <% fluxes = JSON.parse(@spectrum_result.flux_data || "[]") rescue [] %>
  <% sdss_photometry = JSON.parse(@spectrum_result.sdss_photometry || "{}") rescue {} %>

  <% if sdss_photometry.present? %>
    <div class="cyberspace-panel">
      <div class="card-header">
        <div>
          <h2 class="card-title">SDSS Photometry<%= target_name.present? ? " — #{target_name}" : "" %></h2>
        </div>
      </div>
      <div class="cyberspace-panel-body">
        <table>
          <thead>
            <tr>
              <th>Band</th>
              <th>Magnitude</th>
            </tr>
          </thead>
          <tbody>
            <% %w[u g r i z].each do |band| %>
              <% next if sdss_photometry[band].nil? %>
              <tr>
                <td><%= band %></td>
                <td><%= sdss_photometry[band] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <div class="cyberspace-panel">
    <div class="card-header">
      <div>
        <h2 class="card-title">Composite Spectrum<%= target_name.present? ? " — #{target_name}" : "" %></h2>
      </div>
    </div>
    <div class="cyberspace-panel-body">
  <% spectrum_points = wavelengths.each_with_index.map { |wavelength, idx| [wavelength.to_f, fluxes[idx].to_f] } %>
  <canvas id="spectrum-canvas" height="320" style="display: block; width: 100%; border: 1px solid #334155; margin-bottom: 12px;"></canvas>

  <script>
    (function() {
      const canvas = document.getElementById("spectrum-canvas");
      const table = document.getElementById("composite-spectrum-table");
      if (!canvas) return;
      const points = <%= raw(spectrum_points.to_json) %>;
      if (!points || points.length < 2) return;

      const ctx = canvas.getContext("2d");
      const pad = { left: 52, right: 16, top: 16, bottom: 36 };

      function draw() {
        const cssWidth = (table && table.clientWidth) ? table.clientWidth : canvas.clientWidth;
        const cssHeight = 320;
        const dpr = window.devicePixelRatio || 1;

        canvas.style.width = cssWidth + "px";
        canvas.style.height = cssHeight + "px";
        canvas.width = Math.round(cssWidth * dpr);
        canvas.height = Math.round(cssHeight * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

        const w = cssWidth;
        const h = cssHeight;
        const xs = points.map((p) => p[0]);
        const ys = points.map((p) => p[1]);
        const minX = Math.min(...xs);
        const maxX = Math.max(...xs);
        const minY = Math.min(...ys);
        const maxY = Math.max(...ys);
        const xSpan = Math.max(maxX - minX, 1e-9);
        const ySpan = Math.max(maxY - minY, 1e-9);

        const xToPx = (x) => pad.left + ((x - minX) / xSpan) * (w - pad.left - pad.right);
        const yToPx = (y) => (h - pad.bottom) - ((y - minY) / ySpan) * (h - pad.top - pad.bottom);

        ctx.clearRect(0, 0, w, h);
        ctx.fillStyle = "#0b1220";
        ctx.fillRect(0, 0, w, h);

        ctx.strokeStyle = "#64748b";
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(pad.left, pad.top);
        ctx.lineTo(pad.left, h - pad.bottom);
        ctx.lineTo(w - pad.right, h - pad.bottom);
        ctx.stroke();

        ctx.strokeStyle = "#22d3ee";
        ctx.lineWidth = 2;
        ctx.beginPath();
        points.forEach((p, idx) => {
          const px = xToPx(p[0]);
          const py = yToPx(p[1]);
          if (idx === 0) ctx.moveTo(px, py);
          else ctx.lineTo(px, py);
        });
        ctx.stroke();

        ctx.fillStyle = "#94a3b8";
        ctx.font = "12px monospace";
        ctx.fillText("Wavelength (nm)", w / 2 - 48, h - 10);
        ctx.save();
        ctx.translate(14, h / 2 + 26);
        ctx.rotate(-Math.PI / 2);
        ctx.fillText("Flux", 0, 0);
        ctx.restore();
        ctx.fillText(minX.toFixed(1), pad.left - 12, h - pad.bottom + 16);
        ctx.fillText(maxX.toFixed(1), w - pad.right - 28, h - pad.bottom + 16);
        ctx.fillText(maxY.toFixed(3), 6, pad.top + 10);
        ctx.fillText(minY.toFixed(3), 6, h - pad.bottom);
      }

      draw();
      window.addEventListener("resize", draw);
    })();
  </script>

  <details>
    <summary>Composite Spectrum Data Table</summary>
    <table id="composite-spectrum-table">
      <thead>
        <tr>
          <th>Wavelength (nm)</th>
          <th>Flux</th>
        </tr>
      </thead>
      <tbody>
        <% wavelengths.each_with_index do |wavelength, idx| %>
          <tr>
            <td><%= wavelength %></td>
            <td><%= fluxes[idx] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </details>
    </div>
  </div>

<% else %>
  <p>No spectrum result yet.</p>
<% end %>

<div class="run-show-actions">
  <p><%= link_to "Back to Runs", synthesis_runs_path %></p>
  <% if %w[pending running].include?(@synthesis_run.status.to_s) %>
    <span class="delete-disabled-note">Delete disabled while run is pending/running.</span>
  <% else %>
    <%= button_to "Delete Run",
                  synthesis_run_path(@synthesis_run),
                  method: :delete,
                  class: "danger-button",
                  form: { class: "danger-button-form" },
                  data: { turbo_confirm: "Delete this run permanently?" } %>
  <% end %>
</div>
