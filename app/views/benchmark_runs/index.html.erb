<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h1 class="card-title">Benchmark Runs</h1>
      <p class="card-subtitle">Science benchmark checks against reference galaxies.</p>
    </div>
    <div>
      <%= link_to "New Benchmark Run", new_benchmark_run_path, class: "benchmark-new-button" %>
    </div>
  </div>
  <div class="cyberspace-panel-body">
    <p><strong>Active SDSS dataset:</strong> <code><%= @active_sdss_release %></code></p>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Status</th>
            <th>Mode</th>
            <th>Runtime (s)</th>
            <th>Summary</th>
            <th>Created At</th>
          </tr>
        </thead>
        <tbody>
          <% @benchmark_runs.each do |run| %>
            <% parsed = JSON.parse(run.result_json || "{}") rescue {} %>
            <% summary = parsed["summary"] || {} %>
            <% run_mode = parsed["mode"].to_s.presence || "-" %>
            <tr>
              <td><%= link_to(run.name, benchmark_run_path(run)) %></td>
              <td><%= run.status %></td>
              <td><%= run_mode %></td>
              <td><%= run.runtime_seconds.present? ? run.runtime_seconds : "-" %></td>
              <td>
                <% if summary.present? %>
                  pass=<%= summary["pass"] %>, warn=<%= summary["warn"] %>, fail=<%= summary["fail"] %>
                <% else %>
                  -
                <% end %>
              </td>
              <td><%= run.created_at %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
