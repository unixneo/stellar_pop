<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h1 class="card-title">New Benchmark Run</h1>
      <p class="card-subtitle">Run published-science benchmark checks against the current pipeline.</p>
    </div>
  </div>
  <div class="cyberspace-panel-body">
    <div class="form-card">
      <p><strong>Active SDSS dataset:</strong> <code><%= @active_sdss_release %></code></p>
    </div>
    <%= form_with model: @benchmark_run do |f| %>
      <div class="form-card">
        <p>
          <%= f.label :name, "Benchmark run name" %>
          <%= f.text_field :name, placeholder: "auto-generated if blank" %>
        </p>
      </div>

      <div class="form-card" style="font-family: monospace;">
        <p><strong>Benchmark target for this run:</strong></p>
        <p class="form-help">Select one target from the active SDSS dataset release.</p>
        <p>
          <label for="benchmark_key">Benchmark target</label>
          <%= select_tag :benchmark_key,
                         options_for_select(@benchmarks.map { |benchmark| ["#{benchmark[:name]} (#{benchmark[:type]})", benchmark[:key]] }, params[:benchmark_key]),
                         include_blank: "Select one benchmark target",
                         id: "benchmark_key" %>
        </p>

        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Type</th>
              <th>Expected Age (Gyr)</th>
              <th>Expected Z</th>
            </tr>
          </thead>
          <tbody>
            <% @benchmarks.each do |benchmark| %>
              <tr>
                <td><%= benchmark[:name] %></td>
                <td><%= benchmark[:type] %></td>
                <td><%= benchmark.dig(:expected, :age_gyr_min) %>-<%= benchmark.dig(:expected, :age_gyr_max) %></td>
                <td><%= benchmark.dig(:expected, :metallicity_z_min) %>-<%= benchmark.dig(:expected, :metallicity_z_max) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="form-card">
        <p>
          <label style="display: inline-flex; align-items: center; gap: 8px;">
            <%= check_box_tag :fast_mode, "1", true %>
            <strong>Fast mode</strong> (reduced grid for quicker benchmark turnaround)
          </label>
        </p>
        <p class="form-help">
          Fast mode reduces the number of model combinations per benchmark to speed up execution.
        </p>
      </div>

      <div class="form-card">
        <p><%= f.submit "Start Benchmark" %></p>
      </div>
    <% end %>
  </div>
</div>

<div class="action-links">
  <%= link_to "Back to Benchmark Runs", benchmark_runs_path %>
</div>
