<% processing = %w[pending running].include?(@calibration_run.status.to_s) %>
<% elapsed_start_seconds = [Time.current.to_i - @calibration_run.created_at.to_i, 0].max %>
<% result_mode = @result.is_a?(Hash) ? @result["mode"].to_s : "" %>
<%
  inferred_mode = nil
  if result_mode.blank? && processing
    config = PipelineConfig.current
    total_steps = @calibration_run.progress_total.to_i
    benchmark_count =
      begin
        step_text = @calibration_run.current_step.to_s
        if (match = step_text.match(/Benchmark\s+\d+\/(\d+):/))
          match[1].to_i
        elsif @result.is_a?(Hash) && @result["benchmarks"].is_a?(Array)
          @result["benchmarks"].size
        else
          0
        end
      rescue StandardError
        0
      end

    if total_steps.positive? && benchmark_count.positive?
      per_benchmark = total_steps / benchmark_count

      full_ages = config.float_array("grid_ages_gyr")
      full_metallicities = config.float_array("grid_metallicities_z")
      full_imf_types = config.string_array("grid_imf_types")
      full_sfh_models = config.string_array("grid_sfh_models")
      full_burst_ages = config.float_array("grid_burst_ages_gyr")
      full_non_burst = full_sfh_models.reject { |name| name == "burst" }.size
      full_effective_sfh = full_non_burst + full_burst_ages.size
      full_combinations = full_ages.size * full_metallicities.size * full_imf_types.size * full_effective_sfh

      fast_ages = config.float_array("calibration_fast_ages_gyr")
      fast_metallicities = config.float_array("calibration_fast_metallicities_z")
      fast_imf_types = config.string_array("calibration_fast_imf_types")
      fast_sfh_models = config.string_array("calibration_fast_sfh_models")
      fast_burst_ages = config.float_array("calibration_fast_burst_ages_gyr")
      fast_non_burst = fast_sfh_models.reject { |name| name == "burst" }.size
      fast_effective_sfh = fast_non_burst + fast_burst_ages.size
      fast_combinations = fast_ages.size * fast_metallicities.size * fast_imf_types.size * fast_effective_sfh

      inferred_mode =
        if per_benchmark == fast_combinations
          "fast"
        elsif per_benchmark == full_combinations
          "full"
        end
    end
  end
%>
<%
  run_mode_label =
    if result_mode.present?
      result_mode
    elsif inferred_mode.present?
      "#{inferred_mode} (in progress)"
    elsif processing
      "in progress"
    else
      "-"
    end
%>
<%
  status_label =
    case @calibration_run.status.to_s
    when "complete"
      @calibration_run.runtime_seconds.present? ? "completed in #{@calibration_run.runtime_seconds} seconds" : "complete"
    when "failed"
      @calibration_run.runtime_seconds.present? ? "failed after #{@calibration_run.runtime_seconds} seconds" : "failed"
    else
      @calibration_run.status
    end
%>
<% if processing %>
  <% singular_benchmark = @calibration_run.current_step.to_s.match?(/Benchmark\s+\d+\/1:/) %>
  <% banner_mode = result_mode.presence || inferred_mode.presence || "configured" %>
  <meta http-equiv="refresh" content="5">
  <div class="processing-banner" style="padding: 10px 14px; border: 1px solid #f59e0b; background: #2b1f07; color: #fde68a; border-radius: 6px; margin: 0 0 14px 0; font-weight: 600;">
    Running benchmark checks for selected reference <%= singular_benchmark ? "galaxy" : "galaxies" %> (<%= banner_mode %> grid sweep + chi-squared ranking)...
    <span id="processing-elapsed" data-elapsed-seconds="<%= elapsed_start_seconds %>" style="margin-left: 8px; font-family: monospace;">(elapsed: 0s)</span>
  </div>

  <script>
    (function() {
      const elapsedEl = document.getElementById("processing-elapsed");
      if (!elapsedEl) return;

      let elapsedSeconds = parseInt(elapsedEl.dataset.elapsedSeconds || "0", 10);
      function formatElapsed(seconds) {
        const mins = Math.floor(seconds / 60);
        const secs = seconds % 60;
        if (mins > 0) return mins + "m " + secs + "s";
        return secs + "s";
      }

      elapsedEl.textContent = "(elapsed: " + formatElapsed(elapsedSeconds) + ")";
      setInterval(function() {
        elapsedSeconds += 1;
        elapsedEl.textContent = "(elapsed: " + formatElapsed(elapsedSeconds) + ")";
      }, 1000);
    })();
  </script>
<% end %>

<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h1 class="card-title"><%= @calibration_run.name %></h1>
      <p class="card-subtitle">Benchmark run status and results.</p>
    </div>
  </div>
  <div class="cyberspace-panel-body">
    <p><strong>Status:</strong> <%= status_label %></p>
    <p><strong>Run mode:</strong> <%= run_mode_label %></p>
    <% if @calibration_run.runtime_seconds.present? %>
      <p><strong>Runtime:</strong> <%= @calibration_run.runtime_seconds %> seconds</p>
    <% end %>
    <% if @calibration_run.error_message.present? %>
      <p><strong>Error:</strong> <%= @calibration_run.error_message %></p>
    <% end %>
  </div>
</div>

<%
  total = @calibration_run.progress_total.to_i
  completed = [@calibration_run.progress_completed.to_i, total].min
  progress_percent = total.positive? ? ((completed.to_f / total) * 100.0) : 0.0
  elapsed_seconds = [Time.current.to_i - @calibration_run.created_at.to_i, 0].max
  eta_seconds =
    if processing && completed.positive? && total > completed
      ((elapsed_seconds.to_f / completed) * (total - completed)).round
    end
%>
<% if processing || total.positive? %>
  <div class="cyberspace-panel">
    <div class="card-header">
      <div>
        <h2 class="card-title">Calibration Progress</h2>
        <p class="card-subtitle">Live progress for benchmark sweep execution.</p>
      </div>
    </div>
    <div class="cyberspace-panel-body" style="font-family: monospace;">
      <p><strong>Current step:</strong> <%= @calibration_run.current_step.presence || "-" %></p>
      <p><strong>Completed:</strong> <%= completed %> / <%= total %> (<%= format("%.1f", progress_percent) %>%)</p>
      <% if eta_seconds %>
        <p><strong>Estimated remaining:</strong> <%= eta_seconds %> seconds</p>
      <% elsif processing %>
        <p><strong>Estimated remaining:</strong> computing...</p>
      <% end %>
      <div style="height: 10px; border: 1px solid #334155; border-radius: 999px; overflow: hidden; background: rgba(2, 6, 23, 0.85);">
        <div style="height: 100%; width: <%= progress_percent %>%; background: linear-gradient(90deg, #0ea5e9, #22d3ee);"></div>
      </div>
    </div>
  </div>
<% end %>

<% if @result.present? %>
  <% summary = @result["summary"] || {} %>
  <% run_mode = @result["mode"].to_s.presence || "full" %>
  <div class="cyberspace-panel">
    <div class="card-header">
      <div><h2 class="card-title">Summary</h2></div>
    </div>
    <div class="cyberspace-panel-body" style="font-family: monospace;">
      <p>mode=<%= run_mode %></p>
      <p>total=<%= summary["total"] %>, pass=<%= summary["pass"] %>, warn=<%= summary["warn"] %>, fail=<%= summary["fail"] %></p>
    </div>
  </div>

  <% Array(@result["benchmarks"]).each do |benchmark| %>
    <div class="cyberspace-panel">
      <div class="card-header">
        <div>
          <h2 class="card-title"><%= benchmark["name"] %> (<%= benchmark["type"] %>)</h2>
          <p class="card-subtitle">verdict: <strong><%= benchmark["verdict"] %></strong></p>
        </div>
      </div>
      <div class="cyberspace-panel-body">
        <% best = benchmark["best_fit"] || {} %>
        <% expected = benchmark["expected"] || {} %>
        <% references = Array(benchmark["references"]) %>
        <% benchmark_notes = benchmark["notes"].to_s %>
        <% benchmark_type = benchmark["benchmark_type"].to_s %>
        <% best_age = best["age_gyr"].to_f %>
        <% best_z = best["metallicity_z"].to_f %>
        <% age_min = expected["age_gyr_min"].to_f %>
        <% age_max = expected["age_gyr_max"].to_f %>
        <% z_min = expected["metallicity_z_min"].to_f %>
        <% z_max = expected["metallicity_z_max"].to_f %>
        <% expected_sfh = Array(expected["sfh_models"]) %>
        <% age_comparison =
             if best_age < age_min
               "too young"
             elsif best_age > age_max
               "too old"
             else
               "within expected range"
             end %>
        <% z_comparison =
             if best_z < z_min
               "too low"
             elsif best_z > z_max
               "too high"
             else
               "within expected range"
             end %>

        <% if benchmark_type.present? %>
          <p><strong>Benchmark type:</strong> <%= benchmark_type %></p>
        <% end %>
        <% if benchmark_notes.present? %>
          <p><strong>Notes:</strong> <%= benchmark_notes %></p>
        <% end %>
        <p><strong>Published expectation:</strong> age=<%= age_min %>-<%= age_max %> Gyr, Z=<%= z_min %>-<%= z_max %>, sfh=<%= expected_sfh.join(", ") %></p>
        <p><strong>Best fit:</strong> age=<%= best["age_gyr"] %>, Z=<%= best["metallicity_z"] %>, sfh=<%= best["sfh_model"] %>, burst_age=<%= best["burst_age_gyr"] || "-" %>, imf=<%= best["imf_type"] %>, chi2=<%= best["chi_squared"] ? format("%.6f", best["chi_squared"]) : "-" %></p>
        <p><strong>Comparison:</strong> age is <%= age_comparison %>; metallicity is <%= z_comparison %>.</p>
        <% checks = benchmark["checks"] || {} %>
        <p style="font-family: monospace;">checks: age_ok=<%= checks["age_ok"] %>, metallicity_ok=<%= checks["metallicity_ok"] %>, sfh_ok=<%= checks["sfh_ok"] %></p>
        <% if references.any? %>
          <p><strong>References:</strong></p>
          <ul>
            <% references.each do |ref| %>
              <li><%= ref %></li>
            <% end %>
          </ul>
        <% end %>

        <details>
          <summary>Top 10 ranked fits</summary>
          <div class="table-wrap" style="margin-top: 8px;">
            <table>
              <thead>
                <tr>
                  <th>Rank</th>
                  <th>Chi2</th>
                  <th>Age</th>
                  <th>Z</th>
                  <th>SFH</th>
                  <th>Burst Age</th>
                  <th>IMF</th>
                </tr>
              </thead>
              <tbody>
                <% Array(benchmark["top_results"]).first(10).each_with_index do |row, idx| %>
                  <tr>
                    <td><%= idx + 1 %></td>
                    <td><%= row["chi_squared"] ? format("%.6f", row["chi_squared"]) : "-" %></td>
                    <td><%= row["age_gyr"] %></td>
                    <td><%= row["metallicity_z"] %></td>
                    <td><%= row["sfh_model"] %></td>
                    <td><%= row["burst_age_gyr"] || "-" %></td>
                    <td><%= row["imf_type"] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </details>
      </div>
    </div>
  <% end %>
<% end %>

<div class="run-show-actions">
  <div class="action-links">
    <%= link_to "Back to Benchmark Runs", calibration_runs_path %>
  </div>
  <%= button_to "Delete Benchmark Run",
                calibration_run_path(@calibration_run),
                method: :delete,
                class: "danger-button",
                form: { class: "danger-button-form" },
                data: { turbo_confirm: "Delete this benchmark run permanently?" } %>
</div>
