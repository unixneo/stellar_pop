<div class="cyberspace-panel">
  <div class="card-header">
    <div>
      <h1 class="card-title"><%= @galaxy.name %></h1>
      <p class="card-subtitle">Galaxy record details and provenance.</p>
    </div>
    <div><%= link_to "Edit Galaxy", edit_galaxy_path(@galaxy), class: "benchmark-new-button" %></div>
  </div>
  <div class="cyberspace-panel-body">
    <% if @galaxy.sdss_status == "confirmed" %>
      <div style="background-color: #d9fdd3; color: #1a7a1a; border: 1px solid #1a7a1a; padding: 10px; margin-bottom: 12px;">
        SDSS DR19 photometry confirmed
      </div>
    <% elsif @galaxy.sdss_status == "bad_photometry" %>
      <div style="background-color: #ffe0e0; color: #8b0000; border: 1px solid #8b0000; padding: 10px; margin-bottom: 12px;">
        SDSS DR19 photometry unusable - bad photometry
      </div>
    <% elsif @galaxy.sdss_status.nil? %>
      <div style="background-color: #fff9c4; color: #7a5a00; border: 1px solid #7a5a00; padding: 10px; margin-bottom: 12px;">
        SDSS DR19 photometry unconfirmed
      </div>
    <% end %>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>ID</td><td><%= @galaxy.id %></td></tr>
        <tr><td>Type</td><td><%= @galaxy.galaxy_type %></td></tr>
        <tr><td>RA</td><td><%= @galaxy.ra %></td></tr>
        <tr><td>Dec</td><td><%= @galaxy.dec %></td></tr>
        <tr><td>AGN</td><td><%= @galaxy.agn %></td></tr>
        <tr><td>SDSS DR</td><td><%= @galaxy.sdss_dr %></td></tr>
        <tr><td>SDSS ObjID</td><td><%= @galaxy.sdss_objid %></td></tr>
        <tr><td>Source Catalog</td><td><%= @galaxy.source_catalog %></td></tr>
        <tr><td>Notes</td><td><%= @galaxy.notes %></td></tr>
        <tr><td>Created At</td><td><%= @galaxy.created_at %></td></tr>
        <tr><td>Updated At</td><td><%= @galaxy.updated_at %></td></tr>
      </tbody>
    </table>
  </div>
</div>

<div class="cyberspace-panel">
  <div class="card-header">
    <div><h2 class="card-title">Photometry</h2></div>
    <div><%= link_to "Edit Photometry", edit_galaxy_photometry_path(@galaxy), class: "benchmark-new-button" %></div>
  </div>
  <div class="cyberspace-panel-body">
    <% if @photometry.present? %>
      <table>
        <thead>
          <tr>
            <th>Band</th>
            <th>Active Mag</th>
            <th>Petro Mag</th>
            <th>Model Mag</th>
            <th>Error</th>
            <th>Extinction</th>
          </tr>
        </thead>
        <tbody>
          <% [
               %w[u mag_u petro_u model_u err_u extinction_u],
               %w[g mag_g petro_g model_g err_g extinction_g],
               %w[r mag_r petro_r model_r err_r extinction_r],
               %w[i mag_i petro_i model_i err_i extinction_i],
               %w[z mag_z petro_z model_z err_z extinction_z]
             ].each do |band, mag_col, petro_col, model_col, err_col, ext_col| %>
            <tr>
              <td><%= band %></td>
              <td><%= @photometry.public_send(mag_col) %></td>
              <td><%= @photometry.public_send(petro_col) %></td>
              <td><%= @photometry.public_send(model_col) %></td>
              <td><%= @photometry.public_send(err_col) %></td>
              <td><%= @photometry.public_send(ext_col) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <p><strong>Mag Type:</strong> <%= @photometry.mag_type.presence || "-" %> |
         <strong>SDSS Clean:</strong> <%= @photometry.sdss_clean.nil? ? "-" : @photometry.sdss_clean %> |
         <strong>ID Match:</strong> <%= @photometry.id_match_quality.presence || "-" %></p>
    <% else %>
      <p>No photometry record yet.</p>
    <% end %>
  </div>
</div>

<div class="cyberspace-panel">
  <div class="card-header">
    <div><h2 class="card-title">Spectroscopy</h2></div>
    <div><%= link_to "Edit Spectroscopy", edit_galaxy_spectroscopy_path(@galaxy), class: "benchmark-new-button" %></div>
  </div>
  <div class="cyberspace-panel-body">
    <% if @spectroscopy.present? %>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Redshift z</td><td><%= @spectroscopy.redshift_z || "-" %></td></tr>
          <tr><td>z_err</td><td><%= @spectroscopy.z_err || "-" %></td></tr>
          <tr><td>z_warning</td><td><%= @spectroscopy.z_warning || "-" %></td></tr>
          <tr><td>Redshift Source</td><td><%= @spectroscopy.redshift_source.presence || "-" %></td></tr>
          <tr><td>Confidence</td><td><%= @spectroscopy.redshift_confidence.presence || "-" %></td></tr>
          <tr><td>Checked At</td><td><%= @spectroscopy.redshift_checked_at || "-" %></td></tr>
          <tr><td>SDSS DR</td><td><%= @spectroscopy.sdss_dr.presence || "-" %></td></tr>
        </tbody>
      </table>
    <% else %>
      <p>No spectroscopy record yet.</p>
    <% end %>
  </div>
</div>

<div class="cyberspace-panel">
  <div class="card-header">
    <div><h2 class="card-title">Observations</h2></div>
    <div><%= link_to "Add Observation", new_galaxy_observation_path(@galaxy), class: "benchmark-new-button" %></div>
  </div>
  <div class="cyberspace-panel-body">
    <% observations = @galaxy.observations.order(:id) %>
    <% if observations.any? %>
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Source Paper</th>
            <th>Age (Gyr)</th>
            <th>Metallicity (Z)</th>
            <th>Stellar Mass (M☉)</th>
            <th>SFR</th>
            <th>Method</th>
            <th>Notes</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% observations.each do |observation| %>
            <tr>
              <td><%= observation.id %></td>
              <td><%= observation.source_paper %></td>
              <td><%= observation.age_gyr %></td>
              <td><%= observation.metallicity_z %></td>
              <td><%= observation.stellar_mass.present? ? format("%.3e", observation.stellar_mass) : "-" %></td>
              <td><%= observation.sfr %></td>
              <td><%= observation.method_used %></td>
              <td><%= observation.notes %></td>
              <td>
                <%= link_to "Show", observation_path(observation) %> |
                <%= link_to "Edit", edit_observation_path(observation) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p>No observations linked to this galaxy.</p>
    <% end %>
  </div>
</div>

<div class="run-show-actions">
  <div class="action-links">
    <%= link_to "Back to Galaxies", galaxies_path %>
    <%= link_to "Edit", edit_galaxy_path(@galaxy) %>
  </div>
  <%= button_to "Delete Galaxy",
                galaxy_path(@galaxy),
                method: :delete,
                class: "danger-button",
                form: { class: "danger-button-form" },
                data: { turbo_confirm: "Delete this galaxy permanently?" } %>
</div>
